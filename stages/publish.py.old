"""
stages/publish.py — Post article and stills to configured destinations.

Respects testing_mode (drafts) and dry_run (no calls) from config.
Adding a new output destination: add a new function and call it
from publish_all() if enabled in config.
"""

import json
from pathlib import Path

import requests


def publish_all(article_path: str, stills: list, text: str,
                config: dict, logger) -> None:
    """
    Route content to all enabled posting destinations.
 
    Image handling:
      - stills passed in are the originals (used in the article)
      - before any social posting, we crop to a safe aspect ratio
        (width/height >= 0.8) so Instagram and other platforms accept them
      - each service call is wrapped in try/except so one failure
        never prevents the others from running
    """
    from stages.image_filter import crop_for_instagram
 
    posting    = config["posting"]
    test_mode  = config["pipeline"].get("testing_mode", True)
    article_md = Path(article_path).read_text(encoding="utf-8")
    caption    = _make_caption(text, max_chars=2200)
 
    # Crop stills for social posting — originals stay in the article.
    # crop_for_instagram() produces 5:4 (landscape) or 4:5 (portrait)
    # whichever fits the source, always >= 0.75 ratio for Instagram.
    if stills:
        logger.info("Preparing social images (aspect ratio crop)...")
        social_stills = crop_for_instagram(stills, logger)
    else:
        social_stills = stills
 
    if posting.get("wordpress", {}).get("enabled", False):
        logger.info("Publishing to WordPress...")
        try:
            import base64
            post_to_wordpress(article_md, stills, config, logger, test_mode)
        except Exception as e:
            logger.error(f"WordPress publishing failed: {e}")
            logger.info("Continuing with remaining services...")
 
    if posting.get("bundle_social", {}).get("enabled", False):
        logger.info("Publishing to bundle.social...")
        try:
            post_to_bundle(caption, social_stills, config, logger, test_mode)
        except Exception as e:
            logger.error(f"bundle.social publishing failed: {e}")
            logger.info("Continuing with remaining services...")
 
    if posting.get("buffer", {}).get("enabled", False):
        logger.info("Publishing to Buffer...")
        try:
            post_to_buffer(caption, social_stills, config, logger, test_mode)
        except Exception as e:
            logger.error(f"Buffer publishing failed: {e}")
            logger.info("Continuing with remaining services...")



# ── bundle.social ─────────────────────────────────────────────────────────────
# Docs: https://info.bundle.social/api-reference/upload-content

BASE = "https://api.bundle.social/api/v1"


def post_to_bundle(caption: str, stills: list, config: dict,
                   logger, test_mode: bool) -> str:
    """
    Upload images then create a post on bundle.social.
    Uses the Simple Upload method (POST /upload/create, multipart form).
    Returns post ID on success.
    """
    cfg     = config["posting"]["bundle_social"]
    api_key = cfg["api_key"]
    team_id = cfg["team_id"]
    status  = "DRAFT" if test_mode else cfg.get("status", "DRAFT")
    headers = {"x-api-key": api_key}   # NO Content-Type — let requests set it

    # ── Step 1: Upload each still image ──────────────────────────────────
    upload_ids = []
    for still in stills:
        uid = _bundle_upload_image(still, team_id, api_key, logger)
        if uid:
            upload_ids.append(uid)
        else:
            logger.warning(f"Skipping still in post — upload failed: {still}")

    # ── Step 2: Build the post payload ────────────────────────────────────
    active_platforms = {k: v for k, v in cfg.get("platforms", {}).items() if v}
    if not active_platforms:
        logger.warning("bundle.social: no platforms enabled, skipping post")
        return ""

    # Build per-platform content blocks
    platform_key_map = {
        "instagram": "INSTAGRAM",
        "facebook":  "FACEBOOK",
        "threads":   "THREADS",
        "bluesky":   "BLUESKY",
        "linkedin":  "LINKEDIN",
        "twitter":   "TWITTER",
        "pinterest": "PINTEREST",
        "reddit":   "REDDIT",
    }
    post_data = {}
    for key, bundle_key in platform_key_map.items():
        if cfg.get("platforms", {}).get(key, False):
            post_data[bundle_key] = {
                "text":      caption,
                "uploadIds": upload_ids,
            }

    payload = {
        "teamId": team_id,
        "title":  caption[:100],  # bundle.social title max length is 100 chars
        "postDate": _bundle_schedule_time(cfg),  # must be set even for drafts 
        "socialAccountTypes": list(post_data.keys()),
        "status": status,
        "data":   post_data,
    }

    # Add schedule time if posting (not draft)
    if status != "DRAFT":
        payload["postDate"] = _bundle_schedule_time(cfg)

    logger.debug(f"bundle.social post payload: {json.dumps(payload)[:300]}")

    # ── Step 3: Create the post ───────────────────────────────────────────
    response = requests.post(
        f"{BASE}/post",
        headers={**headers, "Content-Type": "application/json"},
        json=payload,
        timeout=30,
    )

    if response.status_code not in (200, 201):
        logger.error(f"bundle.social post error {response.status_code}: "
                     f"{response.text[:500]}")
        response.raise_for_status()

    post_id = response.json().get("id", "?")
    logger.info(f"bundle.social: {status} created, ID {post_id} "
                f"({len(active_platforms)} platform(s), "
                f"{len(upload_ids)} image(s))")
    return str(post_id)


def _bundle_upload_image(image_path: str, team_id: str,
                         api_key: str, logger) -> str | None:
    """
    Upload one image using bundle.social Simple Upload.
    Endpoint: POST /api/v1/upload/create (multipart/form-data)
    Returns upload ID string, or None on failure.
    """
    path = Path(image_path)
    mime = "image/jpeg" if path.suffix.lower() in (".jpg", ".jpeg") else "image/png"

    try:
        with open(path, "rb") as f:
            response = requests.post(
                f"{BASE}/upload/",
                headers={"x-api-key": api_key},
                files={"file": (path.name, f, mime)},
                data={"teamId": team_id},
                timeout=60,
            )

        if response.status_code not in (200, 201):
            logger.warning(f"bundle.social upload {response.status_code}: "
                           f"{response.text[:300]}")
            return None

        data      = response.json()
        upload_id = data.get("id") or data.get("uploadId")
        if not upload_id:
            logger.warning(f"bundle.social upload: no ID in response: {data}")
            return None

        logger.debug(f"bundle.social upload OK: {path.name} → id={upload_id}")
        return str(upload_id)

    except Exception as e:
        logger.warning(f"bundle.social upload exception for {path.name}: {e}")
        return None


def _bundle_schedule_time(cfg: dict) -> str:
    """Return ISO-8601 UTC datetime string for the configured post time."""
    from datetime import datetime, timezone, timedelta
    try:
        import pytz
        tz = pytz.timezone(cfg.get("timezone", "UTC"))
    except Exception:
        tz = timezone.utc

    time_str   = cfg.get("schedule_time", "09:00")
    hour, mins = map(int, time_str.split(":"))
    now        = datetime.now(tz)
    scheduled  = now.replace(hour=hour, minute=mins, second=0, microsecond=0)
    if scheduled <= now:
        scheduled += timedelta(days=1)
    return scheduled.astimezone(timezone.utc).isoformat()


# ── WordPress ─────────────────────────────────────────────────────────────────

def post_to_wordpress(markdown_text: str, stills: list,
                      config: dict, logger, test_mode: bool) -> str:
    import base64

    wp     = config["posting"]["wordpress"]
    base   = wp["url"].rstrip("/")
    token  = base64.b64encode(
        f"{wp['username']}:{wp['app_password']}".encode()
    ).decode()
    auth   = {"Authorization": f"Basic {token}",
               "Content-Type": "application/json"}
    status = "draft" if test_mode else wp.get("status", "draft")

    # Upload images to WP media library
    url_map = {}
    for still in stills:
        wp_url = _wp_upload_image(still, base, auth, logger)
        if wp_url:
            url_map[still] = wp_url

    content = _rewrite_image_paths(markdown_text, url_map)
    title   = _extract_title(markdown_text)

    payload = {"title": title, "content": content, "status": status}

    category = wp.get("category")
    if category:
        payload["categories"] = [
            _wp_get_or_create_category(category, base, auth, logger)
        ]

    r = requests.post(f"{base}/wp-json/wp/v2/posts",
                      headers=auth, json=payload, timeout=30)
    r.raise_for_status()
    post_id = r.json()["id"]
    logger.info(f"WordPress: {status} created, ID {post_id}")
    return str(post_id)


def _wp_upload_image(image_path, base, auth, logger):
    path = Path(image_path)
    mime = "image/jpeg" if path.suffix.lower() in (".jpg", ".jpeg") else "image/png"
    headers = {**auth,
               "Content-Disposition": f'attachment; filename="{path.name}"',
               "Content-Type": mime}
    try:
        with open(path, "rb") as f:
            r = requests.post(f"{base}/wp-json/wp/v2/media",
                              headers=headers, data=f.read(), timeout=60)
        r.raise_for_status()
        return r.json().get("source_url", "")
    except Exception as e:
        logger.warning(f"WP media upload failed for {path.name}: {e}")
        return None


def _wp_get_or_create_category(name, base, auth, logger):
    r = requests.get(f"{base}/wp-json/wp/v2/categories",
                     headers=auth, params={"search": name}, timeout=10)
    r.raise_for_status()
    cats = r.json()
    if cats:
        return cats[0]["id"]
    r2 = requests.post(f"{base}/wp-json/wp/v2/categories",
                       headers=auth, json={"name": name}, timeout=10)
    r2.raise_for_status()
    return r2.json()["id"]


def _rewrite_image_paths(md, url_map):
    for local, wp_url in url_map.items():
        md = md.replace(local, wp_url)
    return md


def _extract_title(md):
    for line in md.splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return "Show Your Work"


# ── Buffer ────────────────────────────────────────────────────────────────────

BUFFER_ENDPOINT = "https://api.buffer.com"
 
_CREATE_POST_MUTATION = """
mutation CreatePost($input: CreatePostInput!) {
  createPost(input: $input) {
    ... on PostActionSuccess {
      post { id status text }
    }
    ... on MutationError {
      message
    }
  }
}
"""
 
 
def post_to_buffer(caption: str, stills: list,
                   config: dict, logger, test_mode: bool) -> None:
    """
    Post to Buffer using the GraphQL API.
    Creates one post per channel defined in config.
    Instagram/Facebook channels get the 5:4 cropped image.
    """
    cfg      = config["posting"]["buffer"]
    api_key  = cfg["api_key"]
    as_draft = test_mode or cfg.get("save_as_draft", True)
    headers  = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type":  "application/json",
    }
 
    channels = cfg.get("channels", [])
    if not channels:
        logger.warning("Buffer: no channels configured — skipping. "
                       "Run: python buffer_channels.py")
        return
 
    # Upload images once to imgbb to get public URLs.
    # Instagram channels get 5:4 crops; others get originals.
    imgbb_key = cfg.get("imgbb_api_key", "")
 
    standard_urls  = []   # originals — for threads, bluesky etc.
    instagram_urls = []   # 5:4 cropped — for instagram, facebook
 
    if stills and imgbb_key:
        from stages.image_filter import crop_for_instagram
        cropped = crop_for_instagram(stills, logger)
 
        for path in stills:
            url = _imgbb_upload(path, imgbb_key, logger)
            if url:
                standard_urls.append(url)
 
        for path in cropped:
            url = _imgbb_upload(path, imgbb_key, logger)
            if url:
                instagram_urls.append(url)
 
    elif stills and not imgbb_key:
        logger.warning("Buffer: imgbb_api_key not set — posting text only. "
                       "Get a free key at imgbb.com to enable image posts.")
 
    for channel in channels:
        channel_id = channel.get("id")
        service    = channel.get("service", "").lower()
        post_type  = channel.get("type", "post")
 
        # Instagram and Facebook need images — skip if we have none
        needs_images = service in ("instagram", "facebook")
        use_urls     = instagram_urls if needs_images else standard_urls
 
        if needs_images and not use_urls:
            logger.warning(f"Buffer: skipping {service} channel {channel_id} "
                           f"— no images available (add imgbb_api_key to config)")
            continue
 
        try:
            post_id = _buffer_create_post(
                caption, use_urls, channel_id,
                service, post_type, as_draft, headers, logger,
            )
            status_word = "draft" if as_draft else "queued"
            img_note    = f", {len(use_urls)} image(s)" if use_urls else ""
            logger.info(f"Buffer: {status_word} created ID {post_id} "
                        f"[{service}]{img_note}")
        except Exception as e:
            logger.error(f"Buffer post failed for {service} channel "
                         f"{channel_id}: {e}")
 
 
def _buffer_create_post(caption: str, image_urls: list, channel_id: str,
                        service: str, post_type: str,
                        as_draft: bool, headers: dict, logger) -> str:
    """Build and send the GraphQL createPost mutation for one channel."""
 
    post_input = {
        "text":           caption,
        "channelId":      channel_id,
        "schedulingType": "automatic",
        "mode":           "addToQueue",
        "saveToDraft":    as_draft,
    }
 
    # Attach images as public URLs
    if image_urls:
        post_input["assets"] = {
            "images": [{"url": u} for u in image_urls]
        }
 
    # Note: Buffer auto-determines post type (photo/video/text) from the
    # assets included. The instagramOptions/facebookOptions fields do NOT
    # exist in Buffer's public GraphQL schema and cause 400 errors.
    # If Buffer adds explicit type support later it will appear in their docs.
 
    r = requests.post(
        BUFFER_ENDPOINT,
        headers=headers,
        json={"query": _CREATE_POST_MUTATION,
              "variables": {"input": post_input}},
        timeout=30,
    )
    if r.status_code != 200:
        # Log full body so we can see exactly what Buffer rejected
        logger.error(f"Buffer HTTP {r.status_code}: {r.text[:600]}")
        r.raise_for_status()
 
    data   = r.json()
    result = data.get("data", {}).get("createPost", {})
 
    if "errors" in data:
        raise RuntimeError(f"GraphQL error: {data['errors']}")
    if "message" in result:
        raise RuntimeError(f"Buffer mutation error: {result['message']}")
 
    return result.get("post", {}).get("id", "unknown")
 
 
def _imgbb_upload(image_path: str, api_key: str, logger) -> str | None:
    """
    Upload one image to imgbb.com and return its public URL.
    Free tier: unlimited uploads, images hosted indefinitely with an account.
    Get a free API key at: https://imgbb.com/
 
    Returns URL string on success, None on failure.
    """
    import base64
    path = Path(image_path)
 
    try:
        with open(path, "rb") as f:
            image_b64 = base64.b64encode(f.read()).decode("utf-8")
 
        r = requests.post(
            "https://api.imgbb.com/1/upload",
            data={"key": api_key, "image": image_b64},
            timeout=30,
        )
        r.raise_for_status()
        data = r.json()
 
        if not data.get("success"):
            logger.warning(f"imgbb upload failed for {path.name}: "
                           f"{data.get('error', {}).get('message', 'unknown')}")
            return None
 
        url = data["data"]["url"]
        logger.debug(f"imgbb upload OK: {path.name} → {url}")
        return url
 
    except Exception as e:
        logger.warning(f"imgbb upload error for {path.name}: {e}")
        return None
 



# ── Shared helpers ────────────────────────────────────────────────────────────

def _make_caption(text: str, max_chars: int = 2200) -> str:
    """Trim text to platform caption length, cutting at a sentence boundary."""
    if len(text) <= max_chars:
        return text.strip()
    trimmed     = text[:max_chars]
    last_period = trimmed.rfind(".")
    if last_period > max_chars * 0.7:
        return trimmed[:last_period + 1].strip()
    return trimmed.rstrip() + "…"
